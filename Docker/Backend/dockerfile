# -------- build --------
FROM node:20-alpine AS builder
WORKDIR /app

ENV NEXT_TELEMETRY_DISABLED=1
# Variable temporal para build (Prisma la necesita pero no la usa en build time)
ENV MONGODB_URL="mongodb://placeholder:27017/placeholder"

# 1. Copiamos solo lo necesario para instalar dependencias correctamente
COPY package*.json ./
COPY prisma ./prisma

RUN npm ci

# 2. Copiamos el resto del código fuente
COPY . .

# 3. Generamos Prisma Client dentro de Alpine
RUN npx prisma generate

# 4. Build Next.js standalone con Turbopack
RUN npm run build --turbopack

# -------- runtime --------
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=4004
ENV HOSTNAME=0.0.0.0

# Copiamos artefactos desde el builder
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./public/.next/static
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/prisma ./prisma

EXPOSE 4004

# Si quieres aplicar el schema antes de levantar:
CMD ["sh", "-c", "node server.js"]
